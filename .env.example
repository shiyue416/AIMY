# AIMY 配置文件 — 填写后保存，aimy 启动时自动加载
# 复制此文件为 .env 并填入真实值

# ═══════════════════════════════════════════
# 飞轮同步 — 本体拉取子体反馈 (sync_feedback.py)
# 获取: https://github.com/settings/tokens → Generate new token (classic)
# 权限: repo (私有仓库) 或 public_repo (公开仓库)
# ═══════════════════════════════════════════
GITHUB_TOKEN=ghp_xxx

# ═══════════════════════════════════════════
# LLM 模型 — 任选一个填即可
# ═══════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-xxx     # Claude (Anthropic)
OPENAI_API_KEY=sk-xxx            # GPT-5.5 / GPT-4 (OpenAI)
LONGCAT_API_KEY=ak_xxx           # 龙猫-2.0 (美团, 国内无需翻墙)
DEEPSEEK_API_KEY=sk-xxx          # DeepSeek (便宜, 挖洞够用)
GROQ_API_KEY=gsk_xxx             # Groq (免费额度, 速度极快)
GEMINI_API_KEY=AIza-xxx          # Gemini (Google)
XAI_API_KEY=xai-xxx              # Grok (xAI)
OPENROUTER_API_KEY=sk-or-xxx     # OpenRouter (聚合上百模型)
MOONSHOT_API_KEY=sk-xxx          # Kimi (月之暗面)
MISTRAL_API_KEY=xxx              # Mistral
TOGETHER_API_KEY=xxx             # Together AI
CEREBRAS_API_KEY=xxx             # Cerebras (极速推理)
PERPLEXITY_API_KEY=pplx-xxx      # Perplexity

# ═══════════════════════════════════════════
# HackerOne API — 飞轮 Step 1 自动拉取 triage 结果
# 获取地址: https://hackerone.com/settings/api_token
# ═══════════════════════════════════════════
H1_USERNAME=你的H1用户名
H1_TOKEN=你的H1_API_Token

# ═══════════════════════════════════════════
# Burp MCP Ultimate — 本地 Burp Suite MCP 扩展
# ═══════════════════════════════════════════
BURP_MCP_TOKEN=你的BurpMCPToken
BURP_MCP_HOST=127.0.0.1
BURP_MCP_PORT=9444

# ═══════════════════════════════════════════
# 运行模式
# ═══════════════════════════════════════════
# veteran (老鸟, 默认) — 过滤低危，输出简洁
# rookie (菜鸟) — 完整输出 + 修复建议
AIMY_MODE=veteran

# bounty (赏金, 默认) — 只读，证明即停
# pentest (渗透) — 后利用链，横向移动
# redteam (红队) — 隐蔽优先，持久化
# auto-pentest (全自动) — 无人介入
AIMY_SCENE=bounty

# ═══════════════════════════════════════════
# 飞轮质量追踪 (内部)
# ═══════════════════════════════════════════
AIMY_TELEMETRY_ENABLED=false
