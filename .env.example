# AIMY 配置文件 — 填写后保存，aimy 启动时自动加载
# 复制此文件为 .env 并填入真实值

# HackerOne API 凭据 — 飞轮 Step 1 自动拉取 triage 结果
# 获取地址: https://hackerone.com/settings/api_token
H1_USERNAME=你的H1用户名
H1_TOKEN=你的H1_API_Token

# Burp MCP Ultimate — 本地 Burp Suite MCP 扩展
BURP_MCP_TOKEN=你的BurpMCPToken
BURP_MCP_HOST=127.0.0.1
BURP_MCP_PORT=9444

# GPT-5.5 — 最强通用模型
GPT5_API_KEY=sk-你的GPT5APIKey

# 美团龙猫 LongCat-2.0 — 1.6T MoE, 1M 上下文
LONGCAT_API_KEY=ak_你的LongCatAPIKey

# 运行模式: veteran (老鸟) / rookie (菜鸟)
AIMY_MODE=rookie

# 场景模式: bounty / pentest / redteam / auto-pentest
AIMY_SCENE=bounty

# ═══════════════════════════════════════════════════════
# 遥测反馈 — 子体→本体 数据回流 (匿名)
# ═══════════════════════════════════════════════════════
#
# 流程: 挖洞测试 → 自动记录 → GitHub Issue → 本体拉取 → 飞轮进化
# 隐私: URL 仅保留域名, 参数值哈希化, 不收集 Cookie/Token/个人身份
#
# 设为 true 开启自动上报（推荐）
AIMY_TELEMETRY_ENABLED=false
# 反馈仓库 (发布后填入)
AIMY_FEEDBACK_REPO=shiyue416/AIMY
# 受限 Token (仅 issues:write 单仓库, 发布后填入)
AIMY_FEEDBACK_TOKEN=
